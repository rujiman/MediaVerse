<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.rujiman.mediatracker.controllers.PlanListViewController"
            styleClass="bg-base">

    <top>
        <VBox style="-fx-background-color: #1c1730; -fx-effect: dropshadow(gaussian, #000000aa, 10, 0, 0, 3);">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button fx:id="backButton"
                        text="← Volver"
                        onAction="#onBack"
                        styleClass="btn-pill-neutral"/>

                <!-- El color se fija dinámicamente en el controller según
                     la lista (WATCH/PLAY/LISTEN), igual patrón que WatchlistView. -->
                <Label fx:id="titleLabel"
                       text="📋 Pienso ver"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 0 0 0 12;"/>

                <HBox HBox.hgrow="ALWAYS"/>

                <!-- Solo visible dentro de una carpeta: vuelve a la raíz de la lista -->
                <Button fx:id="backToRootButton"
                        text="📂 Todas las carpetas"
                        onAction="#onBackToRoot"
                        visible="false" managed="false"
                        styleClass="btn-pill-neutral"/>

                <Button fx:id="newFolderButton"
                        text="+ Nueva carpeta"
                        onAction="#onCreateFolder"
                        styleClass="btn-pill-brand"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox>
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <!-- Estado vacío -->
            <StackPane fx:id="statusPane" VBox.vgrow="ALWAYS">
                <Label fx:id="statusLabel"
                       text="Aquí no hay nada todavía"
                       wrapText="true"
                       styleClass="text-dim"
                       style="-fx-font-size: 16px;"/>
            </StackPane>

            <!-- Grid de carpetas (solo en la raíz) + items -->
            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        visible="false"
                        managed="false"
                        styleClass="scroll-pane-transparent">
                <VBox spacing="20">

                    <!-- Carpetas: solo se muestran en la vista raíz, nunca dentro de otra carpeta -->
                    <VBox fx:id="foldersSection" spacing="10" visible="false" managed="false">
                        <Label text="Carpetas" styleClass="text-heading"/>
                        <FlowPane fx:id="foldersGrid" hgap="14" vgap="14"/>
                    </VBox>

                    <!-- Items sueltos (sin carpeta) en la raíz, o items de la carpeta abierta -->
                    <VBox fx:id="itemsSection" spacing="10">
                        <Label fx:id="itemsSectionLabel" text="Sin carpeta" styleClass="text-heading"/>
                        <FlowPane fx:id="itemsGrid" hgap="16" vgap="16">
                            <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
                        </FlowPane>
                    </VBox>

                </VBox>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
