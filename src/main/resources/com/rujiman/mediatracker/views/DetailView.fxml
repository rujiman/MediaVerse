<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.rujiman.mediatracker.controllers.DetailViewController"
            styleClass="bg-base">

    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 16 20 0 20;">
            <Button fx:id="backButton"
                    text="← Volver"
                    onAction="#onBack"
                    styleClass="btn-pill-neutral"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fx:id="detailScroll"
                    fitToWidth="true"
                    styleClass="scroll-pane-transparent, bg-base">

            <VBox fx:id="detailContainer"
                  spacing="16"
                  styleClass="bg-base">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <!-- Encabezado con Imagen y Título -->
                <HBox spacing="20" alignment="TOP_LEFT">
                    <!-- Imagen -->
                    <ImageView fx:id="detailImage"
                               fitWidth="250"
                               fitHeight="350"
                               preserveRatio="true"/>

                    <!-- Información -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <!-- Título: el color se fija dinámicamente en el
                             controller según el tipo del item (cian=Juego,
                             violeta=Series, magenta=Anime, etc.), por eso
                             no tiene clase CSS fija aquí. -->
                        <Label fx:id="detailTitle"
                               text="Título"
                               wrapText="true"
                               style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

                        <!-- Año y Puntuación -->
                        <HBox spacing="20">
                            <Label fx:id="detailYear" text="2023" styleClass="text-dim"/>
                            <Label fx:id="detailScore" text="⭐ 85/100" styleClass="text-success"/>
                        </HBox>

                        <!-- Valoración personal (1-5 estrellas), independiente de la puntuación de la API -->
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="Tu valoración:" styleClass="text-dim"/>
                            <HBox fx:id="userRatingStars" spacing="2"/>
                        </HBox>

                        <!-- Botones -->
                        <FlowPane hgap="10" vgap="10">
                            <!-- Favorito: color dinámico de sección, fijado
                                 en el controller (igual que el título) -->
                            <Button fx:id="favoriteButton"
                                    text="⭐ Agregar a favoritos"
                                    minWidth="190"
                                    style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-background-radius: 8; -fx-cursor: hand;"
                                    onAction="#onToggleFavorite"/>

                            <Button fx:id="viewedButton"
                                    text="Marcar como visto"
                                    minWidth="170"
                                    styleClass="btn-pill-neutral"
                                    onAction="#onToggleViewed"/>

                            <Button fx:id="openExternalButton"
                                    text="Abrir en navegador"
                                    minWidth="170"
                                    style="-fx-background-color: #0078d4; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-background-radius: 8; -fx-cursor: hand;"
                                    onAction="#onOpenExternal"/>

                            <!-- Tráiler: también color dinámico de sección -->
                            <Button fx:id="trailerButton"
                                    text="▶ Ver tráiler en YouTube"
                                    minWidth="190"
                                    visible="false" managed="false"
                                    style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-background-radius: 8; -fx-cursor: hand;"
                                    onAction="#onOpenTrailer"/>
                        </FlowPane>

                        <!-- Géneros: cada uno como una cápsula pequeña
                             individual (chip), construidas dinámicamente
                             en el controller a partir de item.getGenres() -->
                        <FlowPane fx:id="detailGenresBox" hgap="6" vgap="6"/>

                        <!-- Plataformas -->
                        <Label fx:id="detailPlatforms"
                               text="Plataformas: Netflix, Prime Video"
                               wrapText="true"
                               styleClass="text-dim"/>

                        <!-- Preview de 30s (solo MUSIC, canciones sueltas con preview de Deezer);
                             usa el color de Música (menta) fijo, ya que esta sección
                             solo aparece para items de tipo MUSIC -->
                        <VBox fx:id="previewSection" spacing="6" visible="false" managed="false">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Button fx:id="previewButton"
                                        text="▶ Escuchar preview (30s)"
                                        minWidth="190"
                                        styleClass="btn-circle-music"
                                        style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-background-radius: 8; -fx-cursor: hand;"
                                        onAction="#onTogglePreview"/>
                                <Label fx:id="previewTimeLabel" text="0:00 / 0:30" styleClass="text-dim"/>
                            </HBox>
                            <ProgressBar fx:id="previewProgressBar"
                                         progress="0"
                                         prefWidth="260"
                                         style="-fx-accent: #4dec9e;"/>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- Separador -->
                <Separator styleClass="separator-line"/>

                <!-- Descripción: el color del título de esta sección se
                     fija dinámicamente en el controller, igual que el
                     título principal y el de episodios, según la sección
                     del item (cian=Juego, violeta=Series, etc.) -->
                <VBox spacing="8">
                    <Label fx:id="descriptionHeaderLabel" text="Descripción" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label fx:id="detailDescription"
                           text="Descripción del contenido..."
                           wrapText="true"
                           styleClass="text-body"
                           style="-fx-line-spacing: 4;"/>
                </VBox>

                <!-- Separador antes de episodios -->
                <Separator fx:id="episodesSeparator" styleClass="separator-line" visible="false" managed="false"/>

                <!-- Episodios (solo ANIME / SERIES); la cabecera usa el
                     color dinámico de sección (violeta=Series, magenta=Anime) -->
                <VBox fx:id="episodesSection" spacing="10" visible="false" managed="false">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label fx:id="episodesHeaderLabel"
                               text="Episodios"
                               style="-fx-font-size: 14px; -fx-font-weight: bold;"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

                        <Button fx:id="markAllWatchedButton"
                                text="✔ Marcar todos"
                                onAction="#onMarkAllEpisodesWatched"
                                style="-fx-background-color: #4dec9e; -fx-text-fill: #100c1c; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 6 12 6 12; -fx-background-radius: 6; -fx-cursor: hand;"/>

                        <Button fx:id="unmarkAllWatchedButton"
                                text="✗ Desmarcar todos"
                                onAction="#onUnmarkAllEpisodesWatched"
                                styleClass="btn-pill-neutral"
                                style="-fx-font-size: 11px; -fx-padding: 6 12 6 12; -fx-background-radius: 6;"/>
                    </HBox>

                    <!-- Ir directamente a un episodio concreto: marca del 1 a ese número -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Ya he visto hasta el episodio" styleClass="text-dim"/>
                        <TextField fx:id="jumpToEpisodeField"
                                   promptText="nº"
                                   prefWidth="60"
                                   styleClass="text-field-base"
                                   style="-fx-background-radius: 6; -fx-padding: 4 8 4 8; -fx-font-size: 11px;"/>
                        <Button fx:id="jumpToEpisodeButton"
                                text="Ir"
                                onAction="#onJumpToEpisode"
                                style="-fx-background-color: #0078d4; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 5 14 5 14; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    </HBox>

                    <VBox fx:id="episodesList" spacing="6"/>
                </VBox>

                <!-- Canciones del álbum (solo MUSIC tipo álbum, solo total por ahora) -->
                <VBox fx:id="trackCountSection" spacing="4" visible="false" managed="false">
                    <Label fx:id="trackCountLabel" text="🎵 0 canciones" styleClass="text-dim"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
