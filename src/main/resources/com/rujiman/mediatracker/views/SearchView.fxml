<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.rujiman.mediatracker.controllers.SearchController">

<BorderPane styleClass="bg-base">

    <top>
        <VBox style="-fx-background-color: #1c1730; -fx-effect: dropshadow(gaussian, #000000aa, 10, 0, 0, 3);">
            <padding><Insets top="16" right="20" bottom="12" left="20"/></padding>
            <HBox spacing="12" alignment="CENTER">

                <HBox spacing="14" alignment="CENTER_LEFT">
                    <Button fx:id="hamburgerButton"
                            text="☰"
                            onAction="#toggleNavMenu"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #f0eef5;
                                   -fx-font-size: 20px;
                                   -fx-cursor: hand;
                                   -fx-padding: 0 4 0 0;"/>

                    <ImageView fitWidth="26" fitHeight="26" preserveRatio="true">
                        <image>
                            <Image url="@icons/mediaverse_logo.png"/>
                        </image>
                    </ImageView>
                    <Label text="Mediaverse" styleClass="text-title" style="-fx-font-size: 20px;"/>

                    <Button fx:id="backToHomeButton"
                            text="← Volver"
                            onAction="#goHome"
                            visible="false" managed="false"
                            styleClass="btn-pill-neutral"
                            style="-fx-font-size: 12px; -fx-padding: 6 14 6 14;"/>
                </HBox>

                <HBox HBox.hgrow="ALWAYS"/>

                <HBox fx:id="searchBarBox" spacing="8" alignment="CENTER" visible="false" managed="false">
                    <TextField fx:id="searchField"
                               promptText="Buscar anime, series, pelis , música o videojuegos..."
                               prefWidth="340"
                               styleClass="text-field-base"
                               style="-fx-border-color: #ec4d80; -fx-border-radius: 20;"/>
                    <Button fx:id="searchButton"
                            text="Buscar"
                            onAction="#onSearch"
                            styleClass="btn-pill-brand"/>
                </HBox>

                <HBox HBox.hgrow="ALWAYS"/>

                <StackPane fx:id="profileIconContainer"
                           prefWidth="32" prefHeight="32"
                           maxWidth="32" maxHeight="32"
                           onMouseClicked="#toggleProfileMenu"
                           style="-fx-background-color: #ec4d80;
                                  -fx-background-radius: 50;
                                  -fx-cursor: hand;">
                    <ImageView fx:id="profileIcon"
                               fitWidth="32" fitHeight="32"
                               preserveRatio="true"
                               pickOnBounds="true"
                               visible="false"/>
                    <Label fx:id="profileInitialLabel"
                           text="U"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>

            </HBox>


            <HBox fx:id="filterBarBox" spacing="8" alignment="CENTER_LEFT" visible="false" managed="false" style="-fx-padding: 12 0 0 0;">
                <ToggleButton fx:id="filterAll" text="Todo" selected="true"
                              onAction="#onFilterChanged"
                              styleClass="filter-toggle"/>
                <ToggleButton fx:id="filterAnime" text="🎌 Anime"
                              onAction="#onFilterChanged"
                              styleClass="filter-toggle"/>
                <ToggleButton fx:id="filterSeries" text="📺 Series"
                              onAction="#onFilterChanged"
                              styleClass="filter-toggle"/>
                <ToggleButton fx:id="filterMovie" text="🎬 Películas"
                              onAction="#onFilterChanged"
                              styleClass="filter-toggle"/>
                <ToggleButton fx:id="filterMusic" text="🎵 Música"
                              onAction="#onFilterChanged"
                              styleClass="filter-toggle"/>
                <ToggleButton fx:id="filterGame" text="🎮 Juegos"
                              onAction="#onFilterChanged"
                              styleClass="filter-toggle"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="centerContent">

            <StackPane fx:id="homeContainer" visible="true">
            </StackPane>

            <VBox fx:id="searchContentBox" visible="false">
                <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

                <StackPane fx:id="statusPane" VBox.vgrow="ALWAYS">
                    <VBox spacing="16" alignment="CENTER">
                        <ProgressIndicator fx:id="loadingSpinner"
                                           visible="false"
                                           managed="false"
                                           prefWidth="48" prefHeight="48"
                                           style="-fx-progress-color: #ec4d80;"/>
                        <Label fx:id="statusLabel"
                               text="Busca tu próxima obsesión: anime, series, pelis, música o videojuegos ✨"
                               wrapText="true"
                               textAlignment="CENTER"
                               styleClass="text-dim"
                               style="-fx-font-size: 16px;"/>
                    </VBox>
                </StackPane>

                <ScrollPane fx:id="scrollPane"
                            fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            visible="false"
                            managed="false"
                            styleClass="scroll-pane-transparent">
                    <FlowPane fx:id="resultsGrid"
                              hgap="16" vgap="16"
                              styleClass="bg-transparent">
                        <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                    </FlowPane>
                </ScrollPane>

            </VBox>

        </StackPane>
    </center>

</BorderPane>

    <StackPane fx:id="sideMenu" visible="false"
               style="-fx-background-color: #1c1730;
                      -fx-effect: dropshadow(gaussian, #000000cc, 20, 0, 4, 0);"
               prefWidth="270" maxWidth="270"
               StackPane.alignment="TOP_LEFT">
        <StackPane.margin><Insets top="100"/></StackPane.margin>

        <VBox spacing="14">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane prefWidth="40" prefHeight="40"
                           maxWidth="40" maxHeight="40"
                           style="-fx-background-color: #ec4d80; -fx-background-radius: 50;">
                    <ImageView fx:id="navProfilePicture"
                               fitWidth="40" fitHeight="40"
                               preserveRatio="true"
                               visible="false"/>
                    <Label fx:id="navProfileInitialLabel"
                           text="U"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                </StackPane>

                <Label fx:id="welcomeLabel"
                       text="Bienvenido a tu galaxia, Usuario"
                       wrapText="true"
                       styleClass="text-heading"/>
            </HBox>

            <Separator/>

            <Button text="🏠 Inicio"
                    onAction="#goHome"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav"/>

            <Button text="🔍 Buscar"
                    onAction="#goSearch"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav"/>

            <Button text="⭐ Favoritos"
                    onAction="#openFavorites"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav"/>

            <Button text="📋 Pienso ver"
                    onAction="#openPlanWatch"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav-series"/>

            <Button text="🎮 Pienso jugar"
                    onAction="#openPlanPlay"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav-game"/>

            <Button text="🎵 Pienso escuchar"
                    onAction="#openPlanListen"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav-music"/>

            <Separator/>

            <Button text="📺 Series vistas"
                    onAction="#openWatchedSeries"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav-series"/>

            <Button text="▶️ Series viendo"
                    onAction="#openWatchingSeries"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav-series"/>

            <Button text="🎌 Anime vistos"
                    onAction="#openWatchedAnime"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav-anime"/>

            <Button text="🎌 Anime viendo"
                    onAction="#openWatchingAnime"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav-anime"/>

            <Button text="🎬 Películas vistas"
                    onAction="#openWatchedMovies"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav-movie"/>

            <Button text="🎮 Juegos jugados"
                    onAction="#openGames"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav-game"/>

            <Button text="🎵 Música escuchada"
                    onAction="#openListenedMusic"
                    maxWidth="Infinity"
                    styleClass="btn-flat-nav-music"/>

            <Separator/>

            <Button text="Cerrar sesión"
                    onAction="#logout"
                    maxWidth="Infinity"
                    styleClass="btn-flat-brand"/>

        </VBox>

    </StackPane>

    <StackPane fx:id="profileMenu" visible="false" managed="false"
               style="-fx-background-color: #1c1730;
                      -fx-effect: dropshadow(gaussian, #000000cc, 16, 0, 0, 4);
                      -fx-background-radius: 12;"
               prefWidth="220" maxWidth="220"
               prefHeight="280" maxHeight="280"
               StackPane.alignment="TOP_RIGHT">
        <StackPane.margin><Insets top="64" right="20"/></StackPane.margin>

        <VBox spacing="12" alignment="CENTER">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <StackPane prefWidth="64" prefHeight="64"
                       maxWidth="64" maxHeight="64"
                       onMouseClicked="#onChangeProfilePicture"
                       style="-fx-background-color: #ec4d80;
                              -fx-background-radius: 50;
                              -fx-cursor: hand;">
                <ImageView fx:id="profilePicture"
                           fitWidth="64" fitHeight="64"
                           preserveRatio="true"
                           visible="false"/>
                <Label fx:id="profileInitialLabelBig"
                       text="U"
                       style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 22px;"/>
            </StackPane>

            <Label fx:id="usernameLabel"
                   text="Usuario"
                   wrapText="true"
                   style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>

            <Separator/>

            <Button text="Cambiar nombre de usuario"
                    onAction="#onChangeUsername"
                    maxWidth="Infinity"
                    styleClass="btn-flat-brand"
                    style="-fx-font-size: 12px;"/>

            <Button text="Cambiar contraseña"
                    onAction="#onChangePassword"
                    maxWidth="Infinity"
                    styleClass="btn-flat-brand"
                    style="-fx-font-size: 12px;"/>
        </VBox>
    </StackPane>

    <StackPane fx:id="detailOverlayContainer" visible="false" styleClass="bg-base">
    </StackPane>

</StackPane>
