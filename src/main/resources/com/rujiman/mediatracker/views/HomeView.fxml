<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.rujiman.mediatracker.controllers.HomeController"
            fx:id="homeScroll"
            fitToWidth="true"
            style="-fx-background-color: #0f0f1a; -fx-border-color: transparent;">

    <VBox fx:id="homeRoot" spacing="16" alignment="TOP_CENTER" style="-fx-background-color: #0f0f1a;">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <Label text="✨ Mi MediaVerse"
               style="-fx-text-fill: #e94560; -fx-font-size: 26px; -fx-font-weight: bold; -fx-padding: 0 0 4 0;"/>
        <Label text="Lo que más te gusta, elegido por ti"
               style="-fx-text-fill: #555577; -fx-font-size: 13px; -fx-padding: 0 0 4 0;"/>

        <!-- ===================== FILA SUPERIOR: 3 COLUMNAS DE TAMAÑO FIJO =====================
             Juegos / Series / Anime: ancho y alto SIEMPRE fijos (420 de ancho, grid 4x4
             con altura fija de 610). El HBox se centra para que, en pantallas grandes,
             el fondo (#0f0f1a) ocupe el espacio extra a los lados en vez de estirar
             las cajas o el grid. -->
        <HBox spacing="16" alignment="TOP_CENTER">

            <!-- JUEGOS -->
            <VBox fx:id="gameColumnBox" spacing="12" prefWidth="420" minWidth="420" maxWidth="420"
                  style="-fx-background-color: #16213e; -fx-background-radius: 14;">
                <padding><Insets top="16" right="14" bottom="16" left="14"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🎮 Juegos"
                           style="-fx-text-fill: #eaeaea; -fx-font-size: 15px; -fx-font-weight: bold;"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="editGameButton"
                            text="✏️"
                            onAction="#onEditGameSection"
                            style="-fx-background-color: transparent; -fx-text-fill: #e94560; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 2 6 2 6;"/>
                </HBox>

                <FlowPane fx:id="gameSectionBox" hgap="10" vgap="10" prefHeight="610" minHeight="610"/>

                <Label fx:id="gameEmptyLabel"
                       text="Pulsa ✏️ para elegir tus juegos favoritos"
                       wrapText="true"
                       visible="false" managed="false"
                       style="-fx-text-fill: #555577; -fx-font-size: 11px;"/>
            </VBox>

            <!-- SERIES -->
            <VBox fx:id="seriesColumnBox" spacing="12" prefWidth="420" minWidth="420" maxWidth="420"
                  style="-fx-background-color: #16213e; -fx-background-radius: 14;">
                <padding><Insets top="16" right="14" bottom="16" left="14"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📺 Series"
                           style="-fx-text-fill: #eaeaea; -fx-font-size: 15px; -fx-font-weight: bold;"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="editSeriesButton"
                            text="✏️"
                            onAction="#onEditSeriesSection"
                            style="-fx-background-color: transparent; -fx-text-fill: #e94560; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 2 6 2 6;"/>
                </HBox>

                <FlowPane fx:id="seriesSectionBox" hgap="10" vgap="10" prefHeight="610" minHeight="610"/>

                <Label fx:id="seriesEmptyLabel"
                       text="Pulsa ✏️ para elegir tus series favoritas"
                       wrapText="true"
                       visible="false" managed="false"
                       style="-fx-text-fill: #555577; -fx-font-size: 11px;"/>
            </VBox>

            <!-- ANIME -->
            <VBox fx:id="animeColumnBox" spacing="12" prefWidth="420" minWidth="420" maxWidth="420"
                  style="-fx-background-color: #16213e; -fx-background-radius: 14;">
                <padding><Insets top="16" right="14" bottom="16" left="14"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🎌 Anime"
                           style="-fx-text-fill: #eaeaea; -fx-font-size: 15px; -fx-font-weight: bold;"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="editAnimeButton"
                            text="✏️"
                            onAction="#onEditAnimeSection"
                            style="-fx-background-color: transparent; -fx-text-fill: #e94560; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 2 6 2 6;"/>
                </HBox>

                <FlowPane fx:id="animeSectionBox" hgap="10" vgap="10" prefHeight="610" minHeight="610"/>

                <Label fx:id="animeEmptyLabel"
                       text="Pulsa ✏️ para elegir tu anime favorito"
                       wrapText="true"
                       visible="false" managed="false"
                       style="-fx-text-fill: #555577; -fx-font-size: 11px;"/>
            </VBox>

        </HBox>

        <!-- ===================== FILA INFERIOR: 2 COLUMNAS DE TAMAÑO FIJO =====================
             Música / Películas: cada una con ancho fijo (628), de forma que las dos
             juntas (628+16+628 = 1272) suman aproximadamente el mismo ancho total que
             las 3 columnas de arriba (420+16+420+16+420 = 1292). También centradas. -->
        <HBox spacing="16" alignment="TOP_CENTER">

            <!-- MÚSICA -->
            <VBox fx:id="musicSectionContainer" spacing="10" prefWidth="628" minWidth="628" maxWidth="628"
                  style="-fx-background-color: #16213e; -fx-background-radius: 14;">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🎵 Música"
                           style="-fx-text-fill: #eaeaea; -fx-font-size: 15px; -fx-font-weight: bold;"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="editMusicButton"
                            text="✏️"
                            onAction="#onEditMusicSection"
                            style="-fx-background-color: transparent; -fx-text-fill: #e94560; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 2 6 2 6;"/>
                </HBox>
                <HBox fx:id="musicSectionBox" spacing="12" alignment="CENTER"/>
                <Label fx:id="musicEmptyLabel"
                       text="Pulsa ✏️ para elegir tu música favorita"
                       visible="false" managed="false"
                       style="-fx-text-fill: #555577; -fx-font-size: 11px;"/>
            </VBox>

            <!-- PELÍCULAS -->
            <VBox fx:id="movieSectionContainer" spacing="10" prefWidth="628" minWidth="628" maxWidth="628"
                  style="-fx-background-color: #16213e; -fx-background-radius: 14;">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🎬 Películas"
                           style="-fx-text-fill: #eaeaea; -fx-font-size: 15px; -fx-font-weight: bold;"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="editMovieButton"
                            text="✏️"
                            onAction="#onEditMovieSection"
                            style="-fx-background-color: transparent; -fx-text-fill: #e94560; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 2 6 2 6;"/>
                </HBox>
                <HBox fx:id="movieSectionBox" spacing="12" alignment="CENTER"/>
                <Label fx:id="movieEmptyLabel"
                       text="Pulsa ✏️ para elegir tus películas favoritas"
                       visible="false" managed="false"
                       style="-fx-text-fill: #555577; -fx-font-size: 11px;"/>
            </VBox>

        </HBox>

    </VBox>

</ScrollPane>
