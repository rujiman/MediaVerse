<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.rujiman.mediatracker.controllers.HomeController"
            fx:id="homeScroll"
            fitToWidth="true"
            styleClass="scroll-pane-transparent, bg-base">

    <VBox fx:id="homeRoot" spacing="16" alignment="TOP_CENTER" styleClass="bg-base">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <!-- "Mi MediaVerse" con el mismo degradado multicolor de la
             identidad de marca (Login, header, bordes...), en vez del
             rosa de marca plano (.text-title). -fx-text-fill admite
             linear-gradient igual que -fx-background-color en JavaFX CSS. -->
        <Label text="✨ Mi MediaVerse"
               style="-fx-font-size: 22px; -fx-font-weight: bold;
                      -fx-text-fill: linear-gradient(from 0% 0% to 100% 0%, #4dd9ec, #8b5cf6, #ec4dc0, #ecb14d);"/>
        <Label text="Lo que más te gusta, elegido por ti" styleClass="text-dim"/>

        <!-- ===================== FILA SUPERIOR: 3 COLUMNAS DE TAMAÑO FIJO =====================
             Juegos / Series / Anime: ancho y alto SIEMPRE fijos (400 de ancho, grid 3x4 = 12
             con altura fija de 715). Decisión final tras varios intentos fallidos de hacer
             esto responsive: 3x4 fijo, sin importar la resolución de pantalla, para que
             funcione siempre igual en cualquier tamaño (portátil o monitor grande), sin
             arriesgarse a que el grid se rompa al adaptarse dinámicamente. El HBox se centra
             para que, en pantallas grandes, el fondo ocupe el espacio extra a los lados en
             vez de estirar las cajas o el grid.

             Cada columna usa el color de acento de su propia sección
             (ver theme.css): cian=Juegos, violeta=Series, magenta=Anime,
             tanto en el título como en el botón circular "+". -->
        <HBox spacing="16" alignment="TOP_CENTER">

            <!-- JUEGOS -->
            <VBox fx:id="gameColumnBox" spacing="12" prefWidth="400" minWidth="400" maxWidth="400"
                  styleClass="bg-panel">
                <padding><Insets top="16" right="14" bottom="16" left="14"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🎮 Juegos" styleClass="section-title-game"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="editGameButton"
                            text="+"
                            onAction="#onEditGameSection"
                            minWidth="26" minHeight="26" maxWidth="26" maxHeight="26"
                            styleClass="btn-circle-base, btn-circle-game"/>
                </HBox>

                <FlowPane fx:id="gameSectionBox" hgap="10" vgap="10" prefHeight="715" minHeight="715"/>

                <Label fx:id="gameEmptyLabel"
                       text="Pulsa + para elegir tus juegos favoritos"
                       wrapText="true"
                       visible="false" managed="false"
                       styleClass="text-dim"/>
            </VBox>

            <!-- SERIES -->
            <VBox fx:id="seriesColumnBox" spacing="12" prefWidth="400" minWidth="400" maxWidth="400"
                  styleClass="bg-panel">
                <padding><Insets top="16" right="14" bottom="16" left="14"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📺 Series" styleClass="section-title-series"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="editSeriesButton"
                            text="+"
                            onAction="#onEditSeriesSection"
                            minWidth="26" minHeight="26" maxWidth="26" maxHeight="26"
                            styleClass="btn-circle-base, btn-circle-series"/>
                </HBox>

                <FlowPane fx:id="seriesSectionBox" hgap="10" vgap="10" prefHeight="715" minHeight="715"/>

                <Label fx:id="seriesEmptyLabel"
                       text="Pulsa + para elegir tus series favoritas"
                       wrapText="true"
                       visible="false" managed="false"
                       styleClass="text-dim"/>
            </VBox>

            <!-- ANIME -->
            <VBox fx:id="animeColumnBox" spacing="12" prefWidth="400" minWidth="400" maxWidth="400"
                  styleClass="bg-panel">
                <padding><Insets top="16" right="14" bottom="16" left="14"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🎌 Anime" styleClass="section-title-anime"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="editAnimeButton"
                            text="+"
                            onAction="#onEditAnimeSection"
                            minWidth="26" minHeight="26" maxWidth="26" maxHeight="26"
                            styleClass="btn-circle-base, btn-circle-anime"/>
                </HBox>

                <FlowPane fx:id="animeSectionBox" hgap="10" vgap="10" prefHeight="715" minHeight="715"/>

                <Label fx:id="animeEmptyLabel"
                       text="Pulsa + para elegir tu anime favorito"
                       wrapText="true"
                       visible="false" managed="false"
                       styleClass="text-dim"/>
            </VBox>

        </HBox>

        <!-- ===================== FILA INFERIOR: 2 COLUMNAS DE TAMAÑO FIJO =====================
             Música / Películas: cada una con ancho fijo (608), de forma que las dos
             juntas suman aproximadamente el mismo ancho total que las 3 columnas de
             arriba. También centradas, con su propio color de acento (menta=Música,
             ámbar=Películas). -->
        <HBox spacing="16" alignment="TOP_CENTER">

            <!-- MÚSICA -->
            <VBox fx:id="musicSectionContainer" spacing="10" prefWidth="608" minWidth="608" maxWidth="608"
                  styleClass="bg-panel">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🎵 Música" styleClass="section-title-music"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="editMusicButton"
                            text="+"
                            onAction="#onEditMusicSection"
                            minWidth="26" minHeight="26" maxWidth="26" maxHeight="26"
                            styleClass="btn-circle-base, btn-circle-music"/>
                </HBox>
                <HBox fx:id="musicSectionBox" spacing="12" alignment="CENTER"/>
                <Label fx:id="musicEmptyLabel"
                       text="Pulsa + para elegir tu música favorita"
                       visible="false" managed="false"
                       styleClass="text-dim"/>
            </VBox>

            <!-- PELÍCULAS -->
            <VBox fx:id="movieSectionContainer" spacing="10" prefWidth="608" minWidth="608" maxWidth="608"
                  styleClass="bg-panel">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🎬 Películas" styleClass="section-title-movie"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="editMovieButton"
                            text="+"
                            onAction="#onEditMovieSection"
                            minWidth="26" minHeight="26" maxWidth="26" maxHeight="26"
                            styleClass="btn-circle-base, btn-circle-movie"/>
                </HBox>
                <HBox fx:id="movieSectionBox" spacing="12" alignment="CENTER"/>
                <Label fx:id="movieEmptyLabel"
                       text="Pulsa + para elegir tus películas favoritas"
                       visible="false" managed="false"
                       styleClass="text-dim"/>
            </VBox>

        </HBox>

    </VBox>

</ScrollPane>
